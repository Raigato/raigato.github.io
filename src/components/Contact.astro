---
import { config } from "../data/config";
---

<section id="contact" aria-label="Contact" class="py-24 px-6 border-t border-[#1e1e1e]">
  <div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-center mb-12 font-mono text-xs text-white/50 tracking-widest">
      <span>// CONTACT</span><span>06 / 06</span>
    </div>
    <h2 class="text-6xl font-black tracking-tight leading-none mb-12 uppercase">
      LET'S BUILD SOMETHING<br />GREAT TOGETHER.
    </h2>
    <div class="flex flex-col gap-4 items-start">
      <a
        href={`mailto:${config.email}`}
        class="font-mono text-xs bg-white text-black px-6 py-3 tracking-widest uppercase hover:bg-white/90 transition-colors duration-200"
      >
        GET IN TOUCH →
      </a>
      <div class="flex gap-5">
        <a href={config.socials.github} target="_blank" rel="me noopener noreferrer" aria-label="GitHub" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
        </a>
        <a href={config.socials.linkedin} target="_blank" rel="me noopener noreferrer" aria-label="LinkedIn" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href={config.socials.x} target="_blank" rel="me noopener noreferrer" aria-label="X (Twitter)" class="text-white/40 hover:text-white transition-colors duration-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.629L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
  gsap.registerPlugin(ScrollTrigger)
  gsap.from('#contact', {
    opacity: 0,
    y: 30,
    duration: 0.7,
    ease: 'power2.out',
    scrollTrigger: { trigger: '#contact', start: 'top 85%' },
  })
</script>
