---
import { join } from "node:path";
import sharp from "sharp";

const CHARS = "<>{}[]()#.,:;=+-*/|&@!?%$\"'`~^_";
const WIDTH = 60;

const src = join(process.cwd(), "public/images/portrait.jpg");
const img = sharp(src);
const meta = await img.metadata();
const newH = Math.floor(
  ((meta.height ?? WIDTH) / (meta.width ?? WIDTH)) * WIDTH,
);

const { data, info } = await img
  .resize(WIDTH, newH)
  .raw()
  .toBuffer({ resolveWithObject: true });

type Cell = [number, number, number, number]; // [r, g, b, charCode]
const colorRows: Cell[][] = [];
for (let y = 0; y < newH; y++) {
  const row: Cell[] = [];
  for (let x = 0; x < WIDTH; x++) {
    const i = (y * WIDTH + x) * info.channels;
    const r = data[i],
      g = data[i + 1],
      b = data[i + 2];
    const brightness = (r + g + b) / 3;
    const charIdx = Math.floor((brightness / 255) * (CHARS.length - 1));
    row.push([r, g, b, CHARS.charCodeAt(charIdx)]);
  }
  colorRows.push(row);
}

const colorData = JSON.stringify(colorRows);
---

<section id="hero" class="min-h-screen flex items-center px-6 pt-20 pb-12">
  <h1 class="sr-only">Freelance Fullstack Developer — Gabriel Raymondou</h1>
  <div
    class="w-full max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-0 md:gap-6 items-center"
  >
    <!-- ASCII Portrait -->
    <div class="ascii-wrap group cursor-default select-none order-2 md:order-1">
      <canvas
        id="ascii-art"
        class="block"
        aria-label="ASCII portrait of Gabriel Raymondou"></canvas>
      <script is:inline type="application/json" id="ascii-colors" set:html={colorData} />
      <div class="flex gap-4 mt-2 hidden md:flex">
        <p class="font-mono text-[10px] text-white/20 tracking-widest">[ HOVER ]</p>
        <p class="font-mono text-[10px] text-white/20 tracking-widest">[ CLICK ]</p>
      </div>
    </div>
    <!-- Terminal Typewriter -->
    <div class="terminal font-mono order-1 md:order-2 min-h-[220px]">
      <p class="text-white/30 text-sm mb-4">~/raigato $</p>
      <div id="terminal-lines" class="space-y-1 text-sm">
        <!-- Lines injected by GSAP -->
        <noscript>
          <p>name → Gabriel Raymondou</p>
          <p>role → Fullstack Dev</p>
          <p>location → Cannes, France</p>
          <p>status → Available</p>
        </noscript>
      </div>
      <div id="terminal-ctas" class="mt-8 flex gap-3 opacity-0">
        <a
          href="#contact"
          class="font-mono text-xs bg-white text-black px-4 py-2 font-bold tracking-widest hover:bg-white/90 transition-colors"
        >
          GET IN TOUCH
        </a>
        <a
          href="#projects"
          class="font-mono text-xs border border-white/30 text-white/70 px-4 py-2 tracking-widest hover:border-white hover:text-white transition-all"
        >
          VIEW WORK ↓
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  #ascii-art {
    opacity: 1;
    max-width: 100%;
    aspect-ratio: 1 / 1;
  }
</style>

<script>
  import { gsap } from "gsap";

  // — Terminal typewriter —
  const terminalLines = document.getElementById("terminal-lines")!;
  const terminalCtas = document.getElementById("terminal-ctas")!;

  const lines = [
    { key: "name", val: "Gabriel Raymondou", color: "", blink: false },
    { key: "role", val: "Fullstack Dev", color: "", blink: false },
    { key: "location", val: "Cannes, France", color: "", blink: false },
    {
      key: "status",
      val: "Available ●",
      color: "var(--accent-green)",
      blink: true,
    },
  ];

  const reducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  function typeLine(line: {
    key: string;
    val: string;
    color: string;
    blink: boolean;
  }): Promise<void> {
    return new Promise((resolve) => {
      const el = document.createElement("div");
      el.innerHTML = `<span class="text-white/40">${line.key}</span> → <span style="color:${line.color || "inherit"}"></span><span class="cursor" style="animation: blink 1s infinite; opacity:1">_</span>`;
      terminalLines.appendChild(el);

      const valSpan = el.querySelectorAll("span")[1] as HTMLElement;
      const cursor = el.querySelector(".cursor") as HTMLElement;

      function finalize() {
        if (line.blink) {
          const text = line.val.slice(0, -1);
          const dot = line.val.slice(-1);
          valSpan.innerHTML = `${text}<span style="animation: blink 1.5s ease-in-out infinite">${dot}</span>`;
        }
      }

      if (reducedMotion) {
        valSpan.textContent = line.val;
        finalize();
        cursor.style.display = "none";
        resolve();
        return;
      }

      let i = 0;
      const interval = setInterval(() => {
        valSpan.textContent = line.val.slice(0, ++i);
        if (i >= line.val.length) {
          clearInterval(interval);
          finalize();
          cursor.style.display = "none";
          setTimeout(resolve, 200);
        }
      }, 60);
    });
  }

  async function runTypewriter() {
    if (!reducedMotion) await new Promise((r) => setTimeout(r, 400));
    for (const line of lines) {
      await typeLine(line);
    }
    gsap.to(terminalCtas, {
      opacity: 1,
      duration: reducedMotion ? 0 : 0.4,
      ease: "power2.out",
    });
  }

  runTypewriter();


  // — ASCII canvas reveal + spotlight (full-color on desktop, colored on mobile) —
  type Cell = [number, number, number, number]; // [r, g, b, charCode]
  const colorRows: Cell[][] = JSON.parse(
    document.getElementById("ascii-colors")!.textContent!,
  );

  const canvas = document.getElementById("ascii-art") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  const FONT_SIZE = 14;
  const FONT = `${FONT_SIZE}px ui-monospace, SFMono-Regular, Menlo, monospace`;
  const GLITCH_CHARS = "<>{}[]()#.,:;=+-*/\\|&@!?%$\"'`~^_";
  const SPOTLIGHT_RADIUS = 80; // CSS px

  const isDesktop = window.matchMedia("(hover: hover)").matches;

  await document.fonts.ready;
  ctx.font = FONT;
  const charWidth = ctx.measureText("M").width;
  const LINE_HEIGHT = charWidth; // square cells
  const cols = colorRows[0]?.length ?? 0;

  const dpr = window.devicePixelRatio || 1;
  canvas.width = cols * charWidth * dpr;
  canvas.height = colorRows.length * LINE_HEIGHT * dpr;
  canvas.style.width = `${cols * charWidth}px`;
  canvas.style.height = `${colorRows.length * LINE_HEIGHT}px`;
  ctx.scale(dpr, dpr);

  function lum(r: number, g: number, b: number) {
    return Math.round(0.299 * r + 0.587 * g + 0.114 * b);
  }

  function drawFrame(revealRow: number, glitchProb = 0.5) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = FONT;

    colorRows.forEach((row, rowIdx) => {
      if (rowIdx > revealRow) return;
      const y = rowIdx * LINE_HEIGHT + FONT_SIZE;
      const isFrontier = rowIdx === revealRow;
      let x = 0;
      for (const [r, g, b, charCode] of row) {
        if (r + g + b < 20) {
          ctx.fillStyle = "#0a0a0a";
        } else if (isDesktop) {
          const l = lum(r, g, b);
          ctx.fillStyle = `rgb(${l},${l},${l})`;
        } else {
          ctx.fillStyle = `rgb(${r},${g},${b})`;
        }
        const isGlitch = isFrontier && Math.random() < glitchProb;
        ctx.fillText(
          isGlitch
            ? GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)]
            : String.fromCharCode(charCode),
          x,
          y,
        );
        x += charWidth;
      }
    });
  }

  function drawSpotlight(mouseX: number, mouseY: number) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = FONT;

    colorRows.forEach((row, rowIdx) => {
      const y = rowIdx * LINE_HEIGHT + FONT_SIZE;
      let x = 0;
      for (const [r, g, b, charCode] of row) {
        const dist = Math.hypot(x + charWidth / 2 - mouseX, y - mouseY);
        const blend = r + g + b < 20 ? 0 : Math.max(0, 1 - dist / SPOTLIGHT_RADIUS);
        if (blend === 0 && r + g + b < 20) {
          ctx.fillStyle = "#0a0a0a";
        } else {
          const l = lum(r, g, b);
          ctx.fillStyle = `rgb(${Math.round(l + (r - l) * blend)},${Math.round(l + (g - l) * blend)},${Math.round(l + (b - l) * blend)})`;
        }
        ctx.fillText(
          blend > 0
            ? GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)]
            : String.fromCharCode(charCode),
          x,
          y,
        );
        x += charWidth;
      }
    });
  }

  function drawFullColor() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font = FONT;
    colorRows.forEach((row, rowIdx) => {
      const y = rowIdx * LINE_HEIGHT + FONT_SIZE;
      let x = 0;
      for (const [r, g, b, charCode] of row) {
        ctx.fillStyle = r + g + b < 20 ? "#0a0a0a" : `rgb(${r},${g},${b})`;
        ctx.fillText(String.fromCharCode(charCode), x, y);
        x += charWidth;
      }
    });
  }

  const state = { row: 0 };
  let tween: ReturnType<typeof gsap.to> | null = null;

  if (reducedMotion) {
    drawFrame(colorRows.length);
  } else {
    tween = gsap.to(state, {
      row: colorRows.length - 1,
      duration: 3.5,
      ease: "power3.out",
      onUpdate() {
        const progress = state.row / (colorRows.length - 1);
        drawFrame(Math.floor(state.row), 0.5 * (1 - progress));
      },
      onComplete() {
        drawFrame(colorRows.length);
      },
    });
  }

  if (isDesktop) {
    let mouse = { x: -9999, y: -9999 };
    let rafId: number | null = null;
    let locked = false;

    canvas.addEventListener("click", () => {
      tween?.kill();
      tween = null;
      locked = !locked;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
      locked ? drawFullColor() : drawFrame(colorRows.length);
    });

    canvas.addEventListener("mousemove", (e) => {
      if (locked) return;
      // First hover during animation: skip to end
      if (tween?.isActive()) {
        tween.kill();
        tween = null;
        drawFrame(colorRows.length);
      }
      mouse = { x: e.offsetX, y: e.offsetY };
      if (!rafId) {
        rafId = requestAnimationFrame(() => {
          drawSpotlight(mouse.x, mouse.y);
          rafId = null;
        });
      }
    });

    canvas.addEventListener("mouseleave", () => {
      if (locked) return;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = null;
      drawFrame(colorRows.length);
    });
  }
</script>
