---
import { config } from "../data/config";
import { readFileSync } from "fs";
import { resolve } from "path";

const ascii = readFileSync(resolve("src/data/ascii.txt"), "utf-8");
---

<section
  id="hero"
  class="min-h-screen flex items-center px-6 pt-20 pb-12"
>
  <div class="w-full max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

    <!-- ASCII Portrait -->
    <div class="ascii-wrap group cursor-default select-none">
      <pre
        id="ascii-art"
        class="font-mono text-[5px] leading-tight text-white/70 whitespace-pre overflow-hidden hidden md:block"
        aria-label="ASCII portrait of Gabriel Raymondou"
      >{ascii}</pre>
      <p class="font-mono text-[10px] text-white/20 mt-2 tracking-widest hidden md:block">[ HOVER ]</p>
    </div>

    <!-- Terminal Typewriter -->
    <div class="terminal font-mono">
      <p class="text-white/30 text-sm mb-4">~/gabriel $</p>
      <div id="terminal-lines" class="space-y-1 text-sm">
        <!-- Lines injected by GSAP -->
      </div>
      <div id="terminal-ctas" class="mt-8 flex gap-3 opacity-0">
        <a
          href="#contact"
          class="font-mono text-xs bg-white text-black px-4 py-2 font-bold tracking-widest hover:bg-white/90 transition-colors"
        >
          GET IN TOUCH
        </a>
        <a
          href="#projects"
          class="font-mono text-xs border border-white/30 text-white/70 px-4 py-2 tracking-widest hover:border-white hover:text-white transition-all"
        >
          VIEW WORK ↓
        </a>
      </div>
    </div>

  </div>
</section>

<script>
  import { gsap } from 'gsap'

  // — Terminal typewriter —
  const terminalLines = document.getElementById('terminal-lines')!
  const terminalCtas = document.getElementById('terminal-ctas')!

  const lines = [
    { key: 'name',     val: 'Gabriel Raymondou',  color: '',                      blink: false },
    { key: 'role',     val: 'Fullstack Dev',       color: '',                      blink: false },
    { key: 'location', val: 'Cannes, France',      color: '',                      blink: false },
    { key: 'status',   val: 'Available ●',         color: 'var(--accent-green)',   blink: true  },
  ]

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  function typeLine(line: { key: string; val: string; color: string; blink: boolean }): Promise<void> {
    return new Promise((resolve) => {
      const el = document.createElement('div')
      el.innerHTML = `<span class="text-white/40">${line.key}</span> → <span style="color:${line.color || 'inherit'}"></span><span class="cursor" style="animation: blink 1s infinite; opacity:1">_</span>`
      terminalLines.appendChild(el)

      const valSpan = el.querySelectorAll('span')[1] as HTMLElement
      const cursor = el.querySelector('.cursor') as HTMLElement

      function finalize() {
        if (line.blink) {
          const text = line.val.slice(0, -1)
          const dot = line.val.slice(-1)
          valSpan.innerHTML = `${text}<span style="animation: blink 1.5s ease-in-out infinite">${dot}</span>`
        }
      }

      if (reducedMotion) {
        valSpan.textContent = line.val
        finalize()
        cursor.style.display = 'none'
        resolve()
        return
      }

      let i = 0
      const interval = setInterval(() => {
        valSpan.textContent = line.val.slice(0, ++i)
        if (i >= line.val.length) {
          clearInterval(interval)
          finalize()
          cursor.style.display = 'none'
          setTimeout(resolve, 200)
        }
      }, 60)
    })
  }

  async function runTypewriter() {
    if (!reducedMotion) await new Promise((r) => setTimeout(r, 400))
    for (const line of lines) {
      await typeLine(line)
    }
    gsap.to(terminalCtas, { opacity: 1, duration: reducedMotion ? 0 : 0.4, ease: 'power2.out' })
  }

  runTypewriter()

  // — ASCII glitch on hover —
  const asciiEl = document.getElementById('ascii-art')!
  const originalAscii = asciiEl.textContent ?? ''
  const glitchChars = '░▒▓█▄▀■□▪▫'
  let glitchInterval: ReturnType<typeof setInterval> | null = null

  asciiEl.addEventListener('mouseenter', () => {
    let ticks = 0
    glitchInterval = setInterval(() => {
      if (ticks++ > 5) {
        clearInterval(glitchInterval!)
        asciiEl.textContent = originalAscii
        return
      }
      asciiEl.textContent = originalAscii
        .split('')
        .map((ch) =>
          ch !== '\n' && Math.random() < 0.04
            ? glitchChars[Math.floor(Math.random() * glitchChars.length)]
            : ch,
        )
        .join('')
    }, 50)
  })

  asciiEl.addEventListener('mouseleave', () => {
    if (glitchInterval) clearInterval(glitchInterval)
    asciiEl.textContent = originalAscii
  })
</script>
